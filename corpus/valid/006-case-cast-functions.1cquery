ВЫБРАТЬ
  Ном.Ссылка КАК Ссылка,
  ВЫБОР
    КОГДА Ном.ЭтоГруппа = ИСТИНА ТОГДА "Группа"
    КОГДА Ном.ВидНоменклатуры = &ВидТовар ТОГДА "Товар"
    ИНАЧЕ "Услуга"
  КОНЕЦ КАК ТипНоменклатуры,
  ВЫРАЗИТЬ(Ном.Наименование КАК СТРОКА(100)) КАК КраткоеНаименование,
  ЕСТЬNULL(Ном.Артикул, "") КАК Артикул,
  ПОДСТРОКА(Ном.Наименование, 1, 50) КАК НачалоНаименования,
  ПРЕДСТАВЛЕНИЕ(Ном.ОсновнойПоставщик) КАК Поставщик
ИЗ
  Справочник.Номенклатура КАК Ном
ГДЕ
  НЕ Ном.ПометкаУдаления
  И Ном.Наименование <> ""
